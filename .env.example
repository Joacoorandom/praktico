# ---------- Vercel / Deploy ----------
# URL de la tienda (para previews en WhatsApp/Discord y og:image). En Vercel: https://tu-proyecto.vercel.app
NEXT_PUBLIC_SITE_URL=https://praktico.vercel.app

# ChileExpress Rating API (cotización de envíos)
# En Vercel: Settings → Environment Variables → añadí CHILEXPRESS_API_KEY con la Primary key del portal ChileExpress.
# Sin esta variable el cotizador usa tarifa estimada; con la key usa la API real.
CHILEXPRESS_API_KEY=tu_primary_key_aqui

# Discord: notificación de nuevos pedidos (obligatorio para que el checkout envíe el pedido)
# DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/...
